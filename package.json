{
  "name": "openclaw-converge",
  "version": "0.1.0",
  "private": true,
  "description": "Recoverable Converge workflow runtime MVP",
  "bin": {
    "converge": "bin/converge"
  },
  "files": [
    "README.md",
    "bin/converge",
    "converge/**/*.py",
