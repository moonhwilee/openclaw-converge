{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Converge event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "workflow_id",
    "event_type",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "event_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "start",
        "progress",
        "round_start",
        "round_summary",
        "wait",
        "verify",
        "deterministic_check_recorded",
        "agent_panel_requested",
        "agent_findings_recorded",
        "finding_arbitrated",
        "parent_linked",
        "child_creation_intent",
        "child_workflow_created",
        "child_workflow_collected",
        "checkpoint",
        "advance",
        "complete",
        "fail",
        "visible_update_sent",
        "report_sent",
        "delivery_reserved",
        "recovery_lease_acquired",
        "lease_released",
        "abandon",
        "recovery_wake_delivered",
        "plan_accepted",
        "report_proof",
        "owner_decision",
        "rescope",
        "artifact"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "checkpoint_id": {
      "type": "string"
    },
    "status_after": {
      "type": "string"
    },
    "phase_after": {
      "type": "string"
    },
    "cursor_before": {
      "type": "string"
    },
    "cursor_after": {
      "type": "string"
    },
    "note": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  }
}
